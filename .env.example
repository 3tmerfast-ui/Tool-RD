# Sao chép file này thành .env.local rồi điền giá trị thật. KHÔNG commit .env.local.

# Khoá Gemini API (lấy tại https://aistudio.google.com/apikey)
# Có thể nhập nhiều key, phân tách bằng dấu phẩy để cân tải / né quota.
# GEMINI_API_KEY không còn dùng (đã thay bằng Flow extension + OpenRouter)
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter — phân tích ảnh (vision -> JSON). CẢNH BÁO: VITE_ => lộ ra frontend.
VITE_OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
# (tuỳ chọn) ép extension ID nếu beacon không tự phát hiện được:
# VITE_FLOW_EXTENSION_ID=

# MindeskAPI — tạo ảnh on-prem (thay thế Chrome extension).
# Để trống = dùng Chrome extension như bình thường.
# Điền URL server MindeskAPI (vd: http://localhost:8000) = dùng on-prem qua Google Labs Flow.
# VITE_MINDESK_URL=http://localhost:8000

# Supabase (lấy tại Dashboard → Project Settings → Database / API)
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
